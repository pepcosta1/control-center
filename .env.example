# --- Servidor ---
NODE_ENV=production
PORT=3000
# A la VM (darrere Nginx) deixa 127.0.0.1; en local pots posar 0.0.0.0
HOST=127.0.0.1
# URL pública (necessària per al callback OAuth de Spotify)
# En local: http://127.0.0.1:3000 — a la VM: https://el-teu-domini
BASE_URL=https://el-teu-domini.exemple.com

# --- Sessions ---
# Genera'n un amb: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Usuari administrador ---
ADMIN_USER=admin
# Genera el hash amb: npm run hash-password -- laTevaContrasenya
ADMIN_PASSWORD_HASH=

# --- Accés limitat (opcional) ---
# IPs (separades per comes) que només veuran endolls i llista de la compra
RESTRICTED_IPS=

# --- Meross ---
MEROSS_EMAIL=
MEROSS_PASSWORD=

# --- Spotify (fase 2) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Ha de coincidir EXACTAMENT amb el Redirect URI del Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=https://el-teu-domini.exemple.com/api/spotify/callback

# --- Discord (fase 3) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- Tuya (termòstat Garza) ---
# Access ID/Secret del Cloud Project a iot.tuya.com (Data Center Europa)
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
# device_id del termòstat (Devices del projecte, via "Link Tuya App Account")
TUYA_DEVICE_ID_TERMOSTAT=
# Regió del data center: eu | us | cn | in
TUYA_REGION=eu

# --- Roomba (iRobot; protocol LOCAL — cal accés a la xarxa de casa) ---
# IP local del robot (mira-la a l'app d'iRobot o al router)
ROOMBA_IP=
# Credencials locals del robot. Amb el robot A LA BASE i des d'un PC de la
# mateixa xarxa: npx -p dorita980 get-roomba-password <IP>
# (mantén premut el botó HOME del robot ~2s fins que soni, i llavors executa-ho)
# Per a models nous (i7+, j, s): npx -p dorita980 get-roomba-password-cloud <email> <contrasenya-iRobot>
ROOMBA_BLID=
ROOMBA_PASSWORD=

# --- TP-Link Deco (xarxa mesh; API local NO oficial) ---
# IP o host del Deco principal, accessible des d'on corre el backend (ex: http://192.168.68.1)
DECO_HOST=
# Usuari local del Deco (normalment "admin") i la contrasenya de l'app Deco
DECO_USERNAME=admin
DECO_PASSWORD=
# MAC del dispositiu de referència per detectar presència (ex: AA:BB:CC:DD:EE:FF)
DECO_PRESENCE_MAC=

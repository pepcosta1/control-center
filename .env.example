# --- Servidor ---
NODE_ENV=production
PORT=3000
# A la VM (darrere Nginx) deixa 127.0.0.1; en local pots posar 0.0.0.0
HOST=127.0.0.1
# URL pública (necessària per al callback OAuth de Spotify)
# En local: http://127.0.0.1:3000 — a la VM: https://el-teu-domini
BASE_URL=https://el-teu-domini.exemple.com

# --- Sessions ---
# Genera'n un amb: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Usuari administrador ---
ADMIN_USER=admin
# Genera el hash amb: npm run hash-password -- laTevaContrasenya
ADMIN_PASSWORD_HASH=

# --- Meross ---
MEROSS_EMAIL=
MEROSS_PASSWORD=

# --- Spotify (fase 2) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Ha de coincidir EXACTAMENT amb el Redirect URI del Spotify Developer Dashboard
SPOTIFY_REDIRECT_URI=https://el-teu-domini.exemple.com/api/spotify/callback

# --- Discord (fase 3) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
